page {
  background-color: #F2F2F7;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'SF Pro Display', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #1C1C1E;
  -webkit-font-smoothing: antialiased;
}

.container {
  padding: 20rpx 32rpx;
  padding-bottom: 40rpx;
}

.page {
  padding: 20rpx 32rpx;
  padding-bottom: 40rpx;
}

/* 苹果风卡片 - 毛玻璃质感 */
.card {
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04), 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1C1C1E;
  margin-bottom: 24rpx;
  letter-spacing: -0.5rpx;
}

/* 苹果系统蓝 */
.text-primary {
  color: #007AFF;
}

.text-gray {
  color: #8E8E93;
}

.text-secondary {
  color: #3C3C43;
  opacity: 0.6;
}

.text-sm {
  font-size: 24rpx;
}

.text-lg {
  font-size: 36rpx;
  font-weight: 600;
}

.text-xl {
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-between {
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

/* 苹果风按钮 */
.btn-primary {
  background: #007AFF;
  color: #fff;
  border-radius: 20rpx;
  font-weight: 600;
  font-size: 32rpx;
  border: none;
  letter-spacing: 0;
}

.btn-primary::after {
  border: none;
}
