/* 天气主卡片 - 根据天气动态变化 */
.weather-card {
  color: #fff;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 122, 255, 0.25), 0 12rpx 40rpx rgba(0, 122, 255, 0.15);
}

.weather-card.bg-sunny {
  background: linear-gradient(160deg, #4A90E2, #87CEEB, #B0E0E6);
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 226, 0.25), 0 12rpx 40rpx rgba(74, 144, 226, 0.15);
}

.weather-card.bg-cloudy {
  background: linear-gradient(160deg, #5B8AB8, #8FAFD9, #B8D4E8);
  box-shadow: 0 4rpx 16rpx rgba(91, 138, 184, 0.25), 0 12rpx 40rpx rgba(91, 138, 184, 0.15);
}

.weather-card.bg-overcast {
  background: linear-gradient(160deg, #6C7A89, #95A5A6, #BDC3C7);
  box-shadow: 0 4rpx 16rpx rgba(108, 122, 137, 0.25), 0 12rpx 40rpx rgba(108, 122, 137, 0.15);
}

.weather-card.bg-rainy {
  background: linear-gradient(160deg, #2C3E50, #4A667D, #6B8A9F);
  box-shadow: 0 4rpx 16rpx rgba(44, 62, 80, 0.25), 0 12rpx 40rpx rgba(44, 62, 80, 0.15);
}

.weather-card.bg-snowy {
  background: linear-gradient(160deg, #A8D8EA, #CDE8F3, #E8F4F8);
  box-shadow: 0 4rpx 16rpx rgba(168, 216, 234, 0.25), 0 12rpx 40rpx rgba(168, 216, 234, 0.15);
}

.weather-card.bg-foggy {
  background: linear-gradient(160deg, #9CA3AF, #B8BDC4, #D1D5DB);
  box-shadow: 0 4rpx 16rpx rgba(156, 163, 175, 0.25), 0 12rpx 40rpx rgba(156, 163, 175, 0.15);
}

/* 未来天气卡片 - 根据天气动态变化 */
.forecast-card {
  background: rgba(255, 255, 255, 0.95);
}

.forecast-card.bg-sunny {
  background: linear-gradient(180deg, rgba(240, 248, 255, 0.98), rgba(255, 255, 255, 0.95));
}

.forecast-card.bg-cloudy {
  background: linear-gradient(180deg, rgba(230, 240, 250, 0.98), rgba(255, 255, 255, 0.95));
}

.forecast-card.bg-overcast {
  background: linear-gradient(180deg, rgba(240, 240, 245, 0.98), rgba(255, 255, 255, 0.95));
}

.forecast-card.bg-rainy {
  background: linear-gradient(180deg, rgba(235, 240, 245, 0.98), rgba(255, 255, 255, 0.95));
}

.forecast-card.bg-snowy {
  background: linear-gradient(180deg, rgba(245, 250, 255, 0.98), rgba(255, 255, 255, 0.95));
}

.forecast-card.bg-foggy {
  background: linear-gradient(180deg, rgba(242, 243, 245, 0.98), rgba(255, 255, 255, 0.95));
}

.district-picker {
  margin-bottom: 24rpx;
}

.district-selector {
  display: inline-flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 32rpx;
  padding: 12rpx 28rpx;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  letter-spacing: 1rpx;
}

.weather-main {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.weather-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.weather-type {
  font-size: 36rpx;
  font-weight: 500;
}

.weather-range {
  font-size: 28rpx;
  opacity: 0.8;
}

.weather-temp-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding-left: 40rpx;
}

.weather-temp {
  font-size: 130rpx;
  font-weight: 200;
  letter-spacing: -6rpx;
  line-height: 1;
}

.weather-temp-right {
  display: flex;
  flex-direction: column;
  margin-left: 4rpx;
  margin-top: 10rpx;
}

.weather-temp-unit {
  font-size: 44rpx;
  font-weight: 300;
  opacity: 0.6;
}

.weather-feels-group {
  margin-top: 4rpx;
}

.weather-feels-label {
  font-size: 26rpx;
  opacity: 0.7;
}

.weather-warnings {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.weather-warning-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 59, 48, 0.9);
  padding: 10rpx 20rpx;
  border-radius: 32rpx;
}

.warning-icon {
  font-size: 28rpx;
}

.warning-text {
  font-size: 26rpx;
  font-weight: 500;
}

.weather-info {
  display: flex;
  gap: 32rpx;
  font-size: 26rpx;
  opacity: 0.8;
}

/* 预报列表 - iOS 天气 App 风格 */
.forecast-list {
  background: rgba(0, 0, 0, 0.03);
  border-radius: 20rpx;
  padding: 16rpx 0;
  margin-top: 8rpx;
}

.forecast-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 0.5rpx solid rgba(60, 60, 67, 0.08);
}

.forecast-item:last-child {
  border-bottom: none;
}

.forecast-past {
  opacity: 0.45;
}

.forecast-past .forecast-date,
.forecast-past .forecast-day {
  color: #8E8E93;
}

.forecast-past .temp-high {
  color: #8E8E93;
}

.forecast-past .temp-low {
  color: #AEAEB2;
}

.forecast-date {
  font-size: 28rpx;
  color: #1C1C1E;
  font-weight: 500;
  width: 100rpx;
}

.forecast-day {
  font-size: 28rpx;
  color: #8E8E93;
  margin-left: 24rpx;
  width: 80rpx;
}

.forecast-middle {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.forecast-icon {
  font-size: 44rpx;
  margin-right: 16rpx;
}

.forecast-rain {
  font-size: 26rpx;
  color: #007AFF;
  font-weight: 500;
}

.forecast-temp {
  display: flex;
  align-items: center;
  width: 140rpx;
  justify-content: flex-end;
}

.temp-high {
  font-size: 30rpx;
  color: #1C1C1E;
  font-weight: 600;
  margin-right: 16rpx;
}

.temp-low {
  font-size: 30rpx;
  color: #8E8E93;
  font-weight: 500;
}

.forecast-more-btn {
  text-align: center;
  padding: 32rpx;
  margin-top: 16rpx;
  color: #007AFF;
  font-size: 30rpx;
  font-weight: 500;
}

/* 出行建议 */
.suggest-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 0.5rpx solid rgba(60, 60, 67, 0.1);
}

.suggest-item:last-child {
  border-bottom: none;
}

.suggest-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
  margin-top: 2rpx;
}

.suggest-title {
  font-weight: 600;
  font-size: 30rpx;
  color: #1C1C1E;
  margin-bottom: 8rpx;
}

